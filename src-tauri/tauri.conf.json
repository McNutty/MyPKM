{
  "productName": "Plectica 2.0",
  "identifier": "com.plectica.app",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "npm run --prefix ../src dev",
    "beforeBuildCommand": "npm run --prefix ../src build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Plectica 2.0",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
